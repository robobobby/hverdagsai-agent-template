{
  "agents": {
    "list": [
      {
        "id": "main",
        "name": "Main",
        "workspace": "~/.openclaw/workspace",
        "subagents": {
          "allowAgents": ["blueprint", "forge", "scout", "sherlock", "pixel"]
        }
      },
      {
        "id": "blueprint",
        "name": "Blueprint (Planner)",
        "workspace": "~/.openclaw/workspace-blueprint"
      },
      {
        "id": "forge",
        "name": "Forge (Builder)",
        "workspace": "~/.openclaw/workspace-forge"
      },
      {
        "id": "scout",
        "name": "Scout (Researcher)",
        "workspace": "~/.openclaw/workspace-scout"
      },
      {
        "id": "sherlock",
        "name": "Sherlock (Reviewer)",
        "workspace": "~/.openclaw/workspace-sherlock"
      },
      {
        "id": "pixel",
        "name": "Pixel (Designer)",
        "workspace": "~/.openclaw/workspace-pixel"
      }
    ]
  }
}
